# Pesan untuk AI/Agent: Apa bila anda membuka file ini, cukup lihat. apa bila ingin melakukan perubahan, jangan direct write ke file ini. cukup berikan yang ingin dirubah pada blockcode chat, nanti saya yang akan mengubahnya. Kenapa? Karena file ini tidak masuk ke VCS (git) jadi tidak akan tercatat perubahan apa saja yang terjadi pada file ini.
PORT=3000
USE_DB=true
DATABASE_URL=postgres://postgres:postgres@localhost:5432/printbridge
STORAGE_DIR=d:\code\PrintForm-server\storage

CLIENT_TTL_MS=15000
SESSION_TTL_MS=15000

# ORPHAN_GRACE_MS=120000
ORPHAN_GRACE_MS=5000
# FILE_CLEANUP_INTERVAL_MS=60000
FILE_CLEANUP_INTERVAL_MS=5000
# FILE_QUOTA_BYTES=1073741824
FILE_QUOTA_BYTES=2500000
MAX_UPLOAD_BYTES=1048576
AUTO_DELETE_TERMINAL_JOB_FILES=true

CLIENT_RETENTION_DAYS=20
RETENTION_CLEANUP_INTERVAL_MS=3000
