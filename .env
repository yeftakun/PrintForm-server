# Pesan untuk AI/Agent: Kamu sudah bisa merubah .env ini karena saya sudah masukkan ke VCS.

# =========================
# Core app
# =========================
# Port HTTP utama PrintForm server
PORT=3000
# Gunakan Postgres repository (true) atau JSON storage (false)
USE_DB=true
# Connection string Postgres (wajib saat USE_DB=true)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/printbridge
# Port monitoring app (optional; dipakai oleh /monitoring)
# MONITORING_PORT=3100

# =========================
# Authentication (Step 7)
# =========================
# Aktifkan wajib auth bearer untuk endpoint API utama
AUTH_ENFORCE=true
# Izinkan register user tanpa login (set false jika hanya admin yang boleh membuat akun)
AUTH_ALLOW_PUBLIC_REGISTER=true
# Ganti dengan secret kuat di production
AUTH_ACCESS_TOKEN_SECRET=change-this-access-secret
AUTH_REFRESH_TOKEN_SECRET=change-this-refresh-secret
# Masa berlaku access token (format jsonwebtoken, contoh: 15m, 1h)
AUTH_ACCESS_TOKEN_TTL=15m
# Masa berlaku refresh token dalam hari
AUTH_REFRESH_TOKEN_TTL_DAYS=30
# Cost bcrypt untuk hash password
AUTH_BCRYPT_ROUNDS=12

ACCOUNT_QUEUE_ALLOW_LEGACY_CLIENT_SESSION_CREATE=false

# =========================
# Storage path
# =========================
# Root folder storage lokal (jobs/clients/sessions/pings/files)
STORAGE_DIR=d:\code\PrintForm-server\storage

# =========================
# Presence & session
# =========================
# TTL client untuk status online/offline (ms)
CLIENT_TTL_MS=12000
# TTL session aktif (ms)
SESSION_TTL_MS=30000
# Window tunggu konfirmasi aktif client saat create session (ms)
SESSION_CREATE_CONFIRM_TIMEOUT_MS=6500
# Interval polling selama window konfirmasi create session (ms)
SESSION_CREATE_CONFIRM_POLL_INTERVAL_MS=300
# Grace period saat websocket client putus sebelum dipaksa offline (ms)
REALTIME_CLIENT_OFFLINE_GRACE_MS=1200

# =========================
# Realtime websocket
# =========================
# Path websocket realtime
REALTIME_PATH=/ws
# Interval sinkronisasi presence loop server (ms)
REALTIME_PRESENCE_SYNC_INTERVAL_MS=1000
# Interval ping keepalive websocket server (ms)
REALTIME_PING_INTERVAL_MS=15000

# =========================
# Upload & quota
# =========================
# Batas ukuran upload per file (bytes)
MAX_UPLOAD_BYTES=1048576
# Batas total kuota file aktif (bytes)
FILE_QUOTA_BYTES=2500000
# Hapus file fisik saat job masuk status terminal (done/failed/rejected/canceled)
AUTO_DELETE_TERMINAL_JOB_FILES=true
# Optional override allowlist upload (default sudah ada di src/config.js)
# ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
# ALLOWED_UPLOAD_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.txt,.doc,.docx

# =========================
# Cleanup & retention
# =========================
# Grace sebelum file orphan boleh dihapus (ms)
ORPHAN_GRACE_MS=5000
# Interval job orphan cleanup scanner (ms)
FILE_CLEANUP_INTERVAL_MS=5000
# Retensi data client stale (hari)
CLIENT_RETENTION_DAYS=20
# Interval cleanup retensi stale client/session/job (ms)
RETENTION_CLEANUP_INTERVAL_MS=3000

# =========================
# Rate limit client endpoint
# =========================
# Register endpoint limiter: window & max request per key
CLIENT_REGISTER_RATE_LIMIT_WINDOW_MS=60000
CLIENT_REGISTER_RATE_LIMIT_MAX=20
# Heartbeat endpoint limiter: window & max request per key
CLIENT_HEARTBEAT_RATE_LIMIT_WINDOW_MS=60000
CLIENT_HEARTBEAT_RATE_LIMIT_MAX=120